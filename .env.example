# SofaScore Scraper yapılandırma değişkenleri
API_BASE_URL=https://www.sofascore.com/api/v1
REQUEST_TIMEOUT=20
MAX_RETRIES=3

# Performans ayarları
MAX_CONCURRENT=10
WAIT_TIME_MIN=0.2
WAIT_TIME_MAX=0.5

# Proxy
USE_PROXY=false
PROXY_URL=

# Maç filtreleme ayarları
FETCH_ONLY_FINISHED=true
SAVE_EMPTY_ROUNDS=false

# Circuit breaker ayarları
RATE_LIMIT_THRESHOLD_CONSECUTIVE=20
RATE_LIMIT_THRESHOLD_RATIO=0.9
SERVER_ERROR_THRESHOLD_CONSECUTIVE=50

# Görsel ayarlar
USE_COLOR=true
DATE_FORMAT=%Y-%m-%d %H:%M:%S

# Loglama
LOG_LEVEL=INFO
DEBUG=false

# Dil
LANGUAGE=tr
